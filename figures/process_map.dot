digraph chain {
  rankdir=TB;
  bgcolor="white";
  node [shape=box style="rounded,filled" fontname="Helvetica" fontsize=12 margin="0.18,0.10" width=4.6];
  edge [fontname="Helvetica" fontsize=10 color="#5A5A5A" penwidth=1.4];

  A [label=<<b>1.  Prior vendor — survey &amp; reporting</b><br/><font point-size="10" color="#3A6B3A">Responses collected; vendor&#8217;s own reporting is CORRECT</font>>
     fillcolor="#E8F0E8" color="#4A7A4A"];
  B [label=<<b>2.  Prior vendor data export (raw file)</b><br/><font point-size="10" color="#9A3A3A">13 reverse-worded items NORMALIZED — stored pre-inverted</font>>
     fillcolor="#F7E6E6" color="#B04A4A"];
  C [label=<<b>3.  AHCA macro-enabled Excel tool</b><br/><font point-size="10" color="#9A3A3A">Applies standard reverse-scoring — does NOT undo the normalization</font>>
     fillcolor="#F7E6E6" color="#B04A4A"];
  D [label=<<b>4.  Submission to AHCA PSCS</b><br/><font point-size="10" color="#9A3A3A">Reverse-worded items scored backwards — erroneous result</font>>
     fillcolor="#F4D0D0" color="#B04A4A"];
  FIX [label=<<b>Correction (Beterra)</b><br/><font point-size="10" color="#3A6B3A">Undo the normalization &#8594; literal responses &#8594; correct scores</font>>
     fillcolor="#E8F0E8" color="#4A7A4A"];

  A -> B [label="  divergence enters here" fontcolor="#B04A4A"];
  B -> C [label="  passed through unchanged"];
  C -> D;
  B -> FIX [style=dashed color="#4A7A4A" label="  re-process" fontcolor="#3A6B3A"];

  { rank=same; D; FIX; }
}
